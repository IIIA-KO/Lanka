{
  "Authentication": {
    "Audience": "account",
    "RequireHttpsMetadata": false
  },
  "KeyCloak": {
    "Realm": "lanka"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "Lanka.Gateway"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "lanka-default": {
        "ClusterId": "lanka-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "{**catch-all}"
        },
        "Transform": [
          {
            "PathPattern": "{**catch=all}"
          }
        ]
      },
      "lanka-register": {
        "ClusterId": "lanka-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "users/register"
        },
        "Transform": [
          {
            "PathPattern": "{**catch=all}"
          }
        ]
      },
      "lanka-login": {
        "ClusterId": "lanka-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "users/login"
        },
        "Transform": [
          {
            "PathPattern": "{**catch=all}"
          }
        ]
      },
      "lanka-refresh-token": {
        "ClusterId": "lanka-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "users/refresh-token"
        },
        "Transform": [
          {
            "PathPattern": "{**catch=all}"
          }
        ]
      },
      "wayforpay-callback": {
        "ClusterId": "lanka-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "payments/wayforpay/callback"
        },
        "Transform": [
          {
            "PathPattern": "{**catch=all}"
          }
        ]
      },
      "wayforpay-return": {
        "ClusterId": "lanka-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "payments/wayforpay/return"
        },
        "Transform": [
          {
            "PathPattern": "{**catch=all}"
          }
        ]
      }
    },
    "Clusters": {
      "lanka-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://lanka-api:8080"
          }
        }
      }
    }
  },
  "Cors": {
    "AllowedOrigins": []
  }
}
